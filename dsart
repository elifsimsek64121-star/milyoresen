/// Animated gold coin with TL symbol
class GoldCoin extends StatefulWidget {
  final double size;
  final Duration delay;
  const GoldCoin({super.key, this.size = 28, this.delay = Duration.zero});
  @override
  State<GoldCoin> createState() => _GoldCoinState();
}

class _GoldCoinState extends State<GoldCoin>
    with SingleTickerProviderStateMixin {
  late final AnimationController _c = AnimationController(
    vsync: this,
    duration: const Duration(milliseconds: 1600),
  )..repeat(reverse: true);
  late final Animation<double> _rot = Tween(
    begin: -0.05,
    end: 0.05,
  ).animate(CurvedAnimation(parent: _c, curve: Curves.easeInOut));
  late final Animation<double> _float = Tween(
    begin: 0.0,
    end: 6.0,
  ).animate(CurvedAnimation(parent: _c, curve: Curves.easeInOut));
  late final Animation<double> _shine = Tween(
    begin: 0.6,
    end: 1.0,
  ).animate(CurvedAnimation(parent: _c, curve: Curves.easeInOut));

  @override
  void initState() {
    super.initState();
    Future.delayed(widget.delay, () {
      if (mounted) _c.forward();
    });
  }

  @override
  void dispose() {
    _c.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) => AnimatedBuilder(
    animation: _c,
    builder: (_, __) => Transform.translate(
      offset: Offset(0, -_float.value),
      child: Transform.rotate(
        angle: _rot.value,
        child: Container(
          width: widget.size,
          height: widget.size,
          decoration: BoxDecoration(
            shape: BoxShape.circle,
            gradient: RadialGradient(
              center: const Alignment(-0.3, -0.4),
              radius: 0.75,
              colors: [
                Color.lerp(K.gold0, K.gold1, _shine.value)!,
                K.gold2,
                K.gold3,
                K.gold4,
              ],
              stops: const [0.0, 0.3, 0.65, 1.0],
            ),
            boxShadow: [
              BoxShadow(
                color: K.gold2.withOpacity(0.7 * _shine.value),
                blurRadius: widget.size * 0.8,
                spreadRadius: widget.size * 0.1,
              ),
            ],
          ),
          alignment: Alignment.center,
          child: Text(
            '₺',
            style: TextStyle(
              fontSize: widget.size * 0.44,
              fontWeight: FontWeight.w900,
              color: K.gold4.withOpacity(0.9),
              height: 1,
            ),
          ),
        ),
      ),
    ),
  );
}

/// Neon-glow bordered box with glassmorphism
class GlassBox extends StatelessWidget {
  final Widget child;
  final Color borderColor;
  final double radius;
  final double blur;
  final EdgeInsetsGeometry? padding;
  final Color? bgOverride;
  final double borderWidth;

  const GlassBox({
    super.key,
    required this.child,
    required this.borderColor,
    this.radius = 18,
    this.blur = 16,
    this.padding,
    this.bgOverride,
    this.borderWidth = 1.4,
  });

  @override
  Widget build(BuildContext context) => ClipRRect(
    borderRadius: BorderRadius.circular(radius),
    child: BackdropFilter(
      filter: ImageFilter.blur(sigmaX: blur, sigmaY: blur),
      child: Container(
        padding: padding,
        decoration: BoxDecoration(
          borderRadius: BorderRadius.circular(radius),
          color: bgOverride ?? K.panel.withOpacity(0.72),
          border: Border.all(
            color: borderColor.withOpacity(0.65),
            width: borderWidth,
          ),
          boxShadow: [
            BoxShadow(
              color: borderColor.withOpacity(0.3),
              blurRadius: blur * 1.2,
              spreadRadius: 1,
            ),
            BoxShadow(
              color: borderColor.withOpacity(0.12),
              blurRadius: blur * 3,
            ),
          ],
        ),
        child: child,
      ),
    ),
  );
}

