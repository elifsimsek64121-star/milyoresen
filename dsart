  Widget _buildOption(int i) {
    const letters = ['A', 'B', 'C', 'D'];
    final optCol = K.opts[i];

    if (hidden.contains(i)) {
      return Padding(
        padding: const EdgeInsets.only(bottom: 10),
        child: Container(
          height: 58,
          decoration: BoxDecoration(
            borderRadius: BorderRadius.circular(16),
            color: K.w05,
            border: Border.all(color: K.w10, width: 0.5),
          ),
        ),
      );
    }

    final isSel = selected == i;
    final isCorr = correct == i;

    // Determine display state
    Color stateColor = optCol;
    bool showGlow = false;
    if (answered) {
      if (isCorr) {
        stateColor = K.correct;
        showGlow = true;
      } else if (isSel) {
        stateColor = K.wrong;
        showGlow = true;
      } else
        stateColor = optCol.withOpacity(0.3);
    } else if (isSel) {
      stateColor = K.select;
      showGlow = true;
    }

    return Padding(
      padding: const EdgeInsets.only(bottom: 10),
      child: GestureDetector(
        onTap:
            (answered ||
                hidden.contains(i) ||
                (selected != -1 && (!dipActive || dipTries >= 1)))
            ? null
            : () {
                setState(() => selected = i);
                Future.delayed(const Duration(milliseconds: 900), _reveal);
              },
        child: AnimatedContainer(
          duration: const Duration(milliseconds: 260),
          curve: Curves.easeOut,
          padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 14),
          decoration: BoxDecoration(
            borderRadius: BorderRadius.circular(16),
            gradient: LinearGradient(
              begin: Alignment.centerLeft,
              end: Alignment.centerRight,
              colors: showGlow
                  ? [stateColor.withOpacity(0.28), stateColor.withOpacity(0.10)]
                  : [K.panelMid.withOpacity(0.75), K.panel.withOpacity(0.65)],
            ),
            border: Border.all(
              color: showGlow
                  ? stateColor
                  : optCol.withOpacity(answered ? 0.15 : 0.32),
              width: showGlow ? 1.8 : 1,
            ),
            boxShadow: showGlow
                ? [
                    BoxShadow(
                      color: stateColor.withOpacity(0.42),
                      blurRadius: 20,
                      spreadRadius: 1,
                    ),
                    BoxShadow(
                      color: stateColor.withOpacity(0.15),
                      blurRadius: 40,
                    ),
                  ]
                : [],
          ),
          child: Row(
            children: [
              // Letter badge
              Container(
                width: 40,
                height: 40,
                decoration: BoxDecoration(
                  borderRadius: BorderRadius.circular(11),
                  gradient: LinearGradient(
                    begin: Alignment.topLeft,
                    end: Alignment.bottomRight,
                    colors: showGlow
                        ? [
                            stateColor.withOpacity(0.50),
                            stateColor.withOpacity(0.22),
                          ]
                        : [optCol.withOpacity(0.20), optCol.withOpacity(0.07)],
                  ),
                  border: Border.all(
                    color: showGlow
                        ? stateColor
                        : optCol.withOpacity(answered ? 0.15 : 0.40),
                    width: 1.2,
                  ),
                ),
                alignment: Alignment.center,
                child: Text(
                  letters[i],
                  style: TextStyle(
                    fontWeight: FontWeight.w900,
                    fontSize: 16,
                    color: showGlow
                        ? stateColor
                        : optCol.withOpacity(answered ? 0.3 : 0.85),
                  ),
                ),
              ),
              const SizedBox(width: 13),
              Expanded(
                child: Text(
                  _opts[i],
                  style: TextStyle(
                    fontSize: 15.5,
                    color: answered
                        ? (showGlow ? K.w100 : K.w40)
                        : (showGlow ? K.w100 : K.w80),
