/// Radial spotlight beams from top center
class BeamPainter extends CustomPainter {
  final Color color;
  final double intensity;
  const BeamPainter(this.color, this.intensity);

  @override
  void paint(Canvas canvas, Size size) {
    final cx = size.width / 2;
    for (int i = 0; i < 16; i++) {
      final angle = (i / 16) * 2 * pi - pi / 2;
      final p = Paint()
        ..shader = RadialGradient(
          colors: [color.withOpacity(0.10 * intensity), Colors.transparent],
        ).createShader(Rect.fromLTWH(0, 0, size.width, size.height * 1.6))
        ..style = PaintingStyle.fill;
      final path = Path()
        ..moveTo(cx, -40)
        ..lineTo(
          cx + cos(angle - 0.05) * size.height * 1.8,
          sin(angle - 0.05) * size.height * 1.8,
        )
        ..lineTo(
          cx + cos(angle + 0.05) * size.height * 1.8,
          sin(angle + 0.05) * size.height * 1.8,
        )
        ..close();
      canvas.drawPath(path, p);
    }
  }

  @override
  bool shouldRepaint(BeamPainter o) =>
      o.color != color || o.intensity != intensity;
}

/// Diagonal scan line texture
class ScanlinePainter extends CustomPainter {
  final double opacity;
  const ScanlinePainter(this.opacity);
  @override
  void paint(Canvas canvas, Size size) {
    final p = Paint()
      ..color = Colors.black.withOpacity(opacity * 0.18)
      ..strokeWidth = 1;
    for (double y = 0; y < size.height; y += 3) {
      canvas.drawLine(Offset(0, y), Offset(size.width, y), p);
    }
  }

  @override
  bool shouldRepaint(ScanlinePainter o) => o.opacity != opacity;
}

