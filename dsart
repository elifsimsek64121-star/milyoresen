class _SplashState extends State<SplashScreen> with TickerProviderStateMixin {
  late final AnimationController _master = AnimationController(
    vsync: this,
    duration: const Duration(milliseconds: 3000),
  )..forward();
  late final AnimationController _ambient = AnimationController(
    vsync: this,
    duration: const Duration(milliseconds: 3000),
  )..repeat(reverse: true);

  late final Animation<double> _bgIn = _interval(0.0, 0.25);
  late final Animation<double> _logoIn = _interval(
    0.15,
    0.55,
    curve: Curves.elasticOut,
  );
  late final Animation<double> _titleIn = _interval(
    0.45,
    0.72,
    curve: Curves.easeOutCubic,
  );
  late final Animation<double> _subIn = _interval(0.60, 0.80);
  late final Animation<double> _btnsIn = _interval(0.75, 1.0);

  Animation<double> _interval(
    double b,
    double e, {
    Curve curve = Curves.easeOut,
  }) => Tween(begin: 0.0, end: 1.0).animate(
    CurvedAnimation(
      parent: _master,
      curve: Interval(b, e, curve: curve),
    ),
  );

  late final Animation<double> _glow = Tween(
    begin: 0.6,
    end: 1.0,
  ).animate(CurvedAnimation(parent: _ambient, curve: Curves.easeInOut));
  late final Animation<double> _beamRot = Tween(
    begin: 0.0,
    end: 1.0,
  ).animate(CurvedAnimation(parent: _ambient, curve: Curves.easeInOut));

  @override
  void dispose() {
    _master.dispose();
    _ambient.dispose();
    super.dispose();
  }

  void _goToGame() => Navigator.pushReplacement(
    context,
    PageRouteBuilder(
      transitionDuration: const Duration(milliseconds: 1000),
      pageBuilder: (_, __, ___) => const GameScreen(),
      transitionsBuilder: (_, a, __, child) {
        final c = CurvedAnimation(parent: a, curve: Curves.easeInOutCubic);
        return FadeTransition(
          opacity: c,
          child: ScaleTransition(
            scale: Tween(begin: 1.06, end: 1.0).animate(c),
            child: child,
          ),
        );
      },
    ),
  );

  @override
  Widget build(BuildContext context) {
    final sz = MediaQuery.of(context).size;
    return Scaffold(
